# =============================================================================
# FreelanceOS Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# ---- Django ----
# For local dev:
DJANGO_SETTINGS_MODULE=config.settings.local
# For Railway production (set in Railway dashboard):
# DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ---- Railway ----
# On Railway, set DJANGO_SETTINGS_MODULE=config.settings.production
# All other env vars below are set in the Railway dashboard as service variables.
# DATABASE_URL and REDIS_URL are auto-injected by Railway when you link a
# Postgres or Redis plugin to your service.
RAILWAY_ENVIRONMENT=production

# ---- Database ----
DATABASE_URL=postgres://freelanceos:freelanceos@localhost:5432/freelanceos
POSTGRES_DB=freelanceos
POSTGRES_USER=freelanceos
POSTGRES_PASSWORD=freelanceos

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Local Dev ----
# Set to True to run Celery tasks synchronously (no worker needed locally)
CELERY_EAGER=False

# ---- Email ----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@freelanceos.io

# ---- Storage (S3-compatible) ----
# USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_CUSTOM_DOMAIN=

# ---- Security ----
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Sentry (Production) ----
# SENTRY_DSN=

# ---- Google OAuth ----
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ---- JWT ----
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
